<<noidx.nws>>=
Noidx = Noidx or { }
function Noidx.insertAnchor(buf, n)
  local t = List.new {}
  local lbl = Noidx.newdocslabel()
  local k, v
  k, v = NWB.pull(buf)
  while k and n > 0 and k ~= NW_BEGIN_DOCS do
    if k == NW_NL then n = n - 1 end
    List.put(t, {k, v})
    k, v = NWB.pull(buf)
  end
  NWB.put(buf, k, v)
  NWB.put(buf, NW_XREF_LABEL, lbl)
  n = List.length(t)
  while n > 0 do
    local p = t[n]
    NWB.put(buf, p[1], p[2])
    n = n - 1
  end
  return lbl
end
