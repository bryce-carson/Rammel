<<list.nws>>=
function List.concat(l1, l2)
  local l, i, n, m
  l = {}
  i = 1
  n = List.length(l1)
  while (i <= n) do
    l[i] = l1[i]
    i = i + 1
  end
  m = List.length(l2)
  i = 1
  while (i <= m) do
    l[i+n] = l2[i]
    i = i + 1
  end
  return l
end

