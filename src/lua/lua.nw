    function Stages.autodefs(sourcebuf, sinkbuf, watcher)
      procedure go()
      local line
      while line := read() do {
          apply(prepass, line)
          write(line)
          if match("@fatal ", line) then exit(1)
            apply(postpass, line)
            }
