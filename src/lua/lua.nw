function Noidx.lognowebchunks(sinkbuf)
  if Noidx.logged_chunks then return end
  Noidx.logged_chunks = 1

  local l = sort(alphacmp, Set.members(allchunks))
  NWB.put(sinkbuf, NW_XREF_BEGINCHUNKS)
