function dumpitems(items, cs)
  local i, n 
  if items and List.length(items) > 0 then
    i, n = 1, List.length(items)
    writes("\\", cs, "{")
    while i <= n do
      writes("\\\\{", items[i], "}")
      i = i + 1
    end
    writes("}")
  end
end
