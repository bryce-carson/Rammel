  elseif matchpattern(a, "-*") then List.put(opt, a)
  elseif matchpattern(a, "*") then List.put(arg, a)
  else error("This can't happen! Arg did not match *: " .. a)
  end
end

P = MPipe

if System.getenv("PATH") then
