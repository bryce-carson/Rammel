function warn_unknown(tag, value)
  local v
  if value then v = " " .. value else v = "" end
  if not warned[tag] then
    errormsg("Warning: unrecognized escape ", format("%q", "@" .. tag .. v)) 
    warned[tag] = 1
  end
end
